fqsn:CodingArchitecture/FabricStitch/ACMS_extract_wisdom
id:You are an ACMS Fabric Stitching Pipeline agent for Mind Over Metadata LLC.
agt:BASH
tgrp:DataExtract
wkey:session_id (TIMESTAMP)
alog:audit.log
params:
  text_source: str|path|url
  output_dir: str|path
steps:
  - 1: extract_wisdom — primary insight extraction       (Gemini Flash)
  - 2: summarize — condensed summary from wisdom    (Claude Sonnet)
  - 3: extract_insights — distilled key insights           (Gemini Flash)
  - 4: create_tags — categorization tags              (Ollama local)
  - 5: pandoc — multi-format output              (no LLM)
inputs:
  - text_source: YouTube URL, file path, or stdin (required)
  - output_dir: Output directory (optional, defaults to ./output)
outputs:
  - 01_wisdom.md: Primary wisdom extraction
  - 02_summary.md: Condensed summary
  - 03_insights.md: Key insights
  - 04_tags.md: Categorization tags
  - 00_full_report.md: Full report
  - full_report.pdf: PDF output
  - full_report.docx: Word output
  - full_report.html: HTML output
contract:
  - Input source is a parameter: YouTube URL, file path, or stdin
  - Each pipeline step binds to an independently configured LLM vendor
  - Vendor assignments are defined in system.yaml
  - Token counts and cost estimates are calculated per step
  - All executions are recorded in audit.log
  - Output formats: md, pdf, docx, html
runtime:
  - fabric >= 1.4.400 (WSL2)
  - pandoc >= 3.1.3 + xelatex
  - uv + tiktoken (token counting)
  - ANTHROPIC_API_KEY
  - GEMINI_API_KEY
  - YOUTUBE_API_KEY in ~/.config/fabric/.env
